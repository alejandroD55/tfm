# =============================================================================
# .env.example — Variables de entorno para desarrollo local
# =============================================================================
# Copia este fichero a .env y rellena los valores:
#   cp .env.example .env
#
# El .env NUNCA debe subirse al repositorio (está en .gitignore)
# =============================================================================

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── S3 ────────────────────────────────────────────────────────────────────────
DATALAKE_BUCKET=tfm-unir-datalake

# ── Dashboard API ─────────────────────────────────────────────────────────────
# Para local, puede ser cualquier string; en EKS debe coincidir con deploy_k8s.sh
DASHBOARD_API_KEY=25aded11b15417a5580f631e432efad66848df1fa2f620e94d26d6b588486431

# ── MongoDB Atlas (dashboard API + bootstrap) ─────────────────────────────────
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=tfm

# ── PostgreSQL local (bootstrap / sync; la API del dashboard lee Mongo) ───────
# docker compose: puerto expuesto 5433 → usa POSTGRES_PORT=5433
# Postgres nativo en Mac: suele ser 5432
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=tfmadmin
POSTGRES_PASSWORD=localpassword123
POSTGRES_DB=tfm
