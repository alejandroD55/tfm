# =============================================================================
# .env.example — Variables de entorno para desarrollo local
# =============================================================================
# Copia este fichero a .env y rellena los valores:
#   cp .env.example .env
#
# El .env NUNCA debe subirse al repositorio (está en .gitignore)
# =============================================================================

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── S3 ────────────────────────────────────────────────────────────────────────
DATALAKE_BUCKET=tfm-unir-datalake

# ── Dashboard API ─────────────────────────────────────────────────────────────
# Para local, puede ser cualquier string; en EKS debe coincidir con deploy_k8s.sh
DASHBOARD_API_KEY=dev-local-key-cambiame

# ── PostgreSQL local (docker-compose) ─────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=tfmadmin
POSTGRES_PASSWORD=localpassword123
POSTGRES_DB=tfm

# ── Aurora AWS (upsert_local_postgres_to_aurora.sh tras bootstrap) ────────────
# AURORA_HOST=127.0.0.1
# AURORA_PORT=15432
# AURORA_USER=tfmadmin
# AURORA_PASSWORD=
# AURORA_DBNAME=tfm
# AURORA_AUTH_MODE=
# AURORA_SECRET_NAME=aurora/credentials
